{
    "name": "heiner/agent-graph",
    "description": "Durable agent graph runtime for Laravel AI SDK agents.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "agent",
        "agent-graph",
        "ai",
        "checkpoint",
        "graph",
        "laravel",
        "laravel-ai",
        "memory",
        "workflow"
    ],
    "homepage": "https://github.com/heinergiehl/agent-graph",
    "support": {
        "issues": "https://github.com/heinergiehl/agent-graph/issues",
        "source": "https://github.com/heinergiehl/agent-graph"
    },
    "require": {
        "php": "^8.3",
        "illuminate/cache": "^12.0 || ^13.0",
        "illuminate/console": "^12.0 || ^13.0",
        "illuminate/contracts": "^12.0 || ^13.0",
        "illuminate/database": "^12.0 || ^13.0",
        "illuminate/events": "^12.0 || ^13.0",
        "illuminate/queue": "^12.0 || ^13.0",
        "illuminate/support": "^12.0 || ^13.0",
        "laravel/ai": "^0.7 || ^1.0"
    },
    "require-dev": {
        "laravel/pint": "^1.26",
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^10.6 || ^11.0",
        "pestphp/pest": "^3.0 || ^4.0",
        "pestphp/pest-plugin-laravel": "^3.0 || ^4.0",
        "phpstan/phpstan": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "Heiner\\AgentGraph\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Heiner\\AgentGraph\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "pest",
        "test:types": "phpstan analyse --memory-limit=1G",
        "test:lint": "pint --test",
        "lint": "pint",
        "check": [
            "@test:lint",
            "@test",
            "@test:types"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Heiner\\AgentGraph\\AgentGraphServiceProvider"
            ],
            "aliases": {
                "AgentGraph": "Heiner\\AgentGraph\\Facades\\AgentGraph"
            }
        },
        "branch-alias": {
            "dev-main": "0.9-dev"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
